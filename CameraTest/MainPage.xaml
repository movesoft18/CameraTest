<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="CameraTest.MainPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CameraView - автоматически управляет своим жизненным циклом -->
        <toolkit:CameraView x:Name="CameraView"
                            Grid.Row="0"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill" />

        <VerticalStackLayout Grid.Row="1"
                             Spacing="10"
                             Padding="20"
                             BackgroundColor="#CCFFFFFF">

            <!-- Предпросмотр сделанного фото/видео -->
            <Image x:Name="PreviewImage"
                   HeightRequest="120"
                   Aspect="AspectFit"
                   BackgroundColor="#E0E0E0"/>

            <Label x:Name="RecordingStatus"
                   Text=""
                   TextColor="Red"
                   FontSize="14"
                   IsVisible="False"
                   HorizontalOptions="Center"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <!-- Кнопка фото -->
                <Button Grid.Column="0"
                        Text="📸 Фото"
                        FontSize="16"
                        BackgroundColor="#2196F3"
                        TextColor="White"
                        CornerRadius="10"
                        Clicked="OnTakePhotoClicked"/>

                <!-- Кнопка видео (меняет текст в зависимости от состояния) -->
                <Button x:Name="VideoButton"
                        Grid.Column="1"
                        Text="🎥 Запись"
                        FontSize="16"
                        BackgroundColor="#4CAF50"
                        TextColor="White"
                        CornerRadius="10"
                        Clicked="OnVideoButtonClicked"/>
            </Grid>

            <!-- Кнопка переключения камеры -->
            <Button Text="🔄 Переключить камеру"
                    FontSize="14"
                    BackgroundColor="#FF9800"
                    TextColor="White"
                    CornerRadius="10"
                    Clicked="OnSwitchCameraClicked"/>

        </VerticalStackLayout>
    </Grid>
</ContentPage>
